# ─── Engram environment ───────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real keys — .env.local is gitignored.

# NPC AI — provider (server-side only; never exposed to the browser).
# The /api/npc route picks a provider automatically, in this priority order:
#   1. ANTHROPIC_API_KEY set → Claude (best in-character writing)
#   2. else GOOGLE_API_KEY set → Gemini 1.5 Flash (free tier)
#   3. neither set → deterministic in-character fallback (UI still clickable)
# You only need ONE of the two keys. Set whichever you have.

# Option 1 — Anthropic Claude. Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Claude model. Sonnet 4.6 = strong in-character writing at chat cost.
# Alternatives: claude-opus-4-8 (max quality) / claude-haiku-4-5 (cheapest).
ENGRAM_MODEL=claude-sonnet-4-6

# Option 2 — Google Gemini (free). Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Gemini model. Flash is fast and free; gemini-1.5-pro for higher quality.
ENGRAM_GEMINI_MODEL=gemini-1.5-flash

# ─── 0G Storage (client-side; the player's wallet pays writes) ────────────────
# WalletConnect project id (https://cloud.walletconnect.com). Optional for injected wallets.
NEXT_PUBLIC_PROJECT_ID=

# 0G Galileo Testnet (Chain ID 16602). The code falls back to these defaults.
NEXT_PUBLIC_L1_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_TURBO_STORAGE_RPC=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_STANDARD_STORAGE_RPC=https://indexer-storage-testnet-standard.0g.ai
