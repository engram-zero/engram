# ─── Engram environment ───────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real keys — .env.local is gitignored.

# NPC AI — provider (server-side only; never exposed to the browser).
# The /api/npc route picks a provider automatically, in this priority order:
#   1. ANTHROPIC_API_KEY set → Claude (best in-character writing)
#   2. else GOOGLE_API_KEY set → Gemini 1.5 Flash (free tier)
#   3. neither set → deterministic in-character fallback (UI still clickable)
# You only need ONE of the two keys. Set whichever you have.

# Option 1 — Anthropic Claude. Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=
# Claude model. Sonnet 4.6 = strong in-character writing at chat cost.
# Alternatives: claude-opus-4-8 (max quality) / claude-haiku-4-5 (cheapest).
ENGRAM_MODEL=claude-sonnet-4-6

# Option 2 — Google Gemini (free). Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Gemini model. Flash is fast and free; gemini-1.5-pro for higher quality.
ENGRAM_GEMINI_MODEL=gemini-1.5-flash

# ─── 0G Storage ───────────────────────────────────────────────────────────────
# Sponsor wallet (SERVER-ONLY, never NEXT_PUBLIC). A funded 0G Galileo testnet
# private key — /api/save writes the memory bundle to 0G with it, because the 0G
# storage SDK can't run in the browser (no CORS). Fund it at faucet.0g.ai.
# Without it, dialogue still works but saving to 0G is disabled.
ENGRAM_SPONSOR_KEY=

# ─── 0G Compute (Prompt 20 — verifiable mining, OPTIONAL, OFF by default) ───────
# When ENGRAM_COMPUTE=1, exhausting a rock makes /api/mine run a REAL, TEE-verified
# inference on the 0G Compute Network (proof-of-useful-work) using the sponsor
# wallet, returning a verifiable receipt. Requires a funded compute ledger first:
#   npm run fund:compute   (needs ENGRAM_SPONSOR_KEY funded with ≥3 testnet OG)
# Both flags must be set to enable it; otherwise mining works locally (no receipt).
ENGRAM_COMPUTE=
NEXT_PUBLIC_ENGRAM_COMPUTE=
# Optional funding amounts for scripts/fund-compute.ts (defaults 3 / 1 OG).
ENGRAM_COMPUTE_LEDGER_OG=
ENGRAM_COMPUTE_PROVIDER_OG=

# WalletConnect project id (https://cloud.walletconnect.com). Optional for injected wallets.
NEXT_PUBLIC_PROJECT_ID=

# 0G Galileo Testnet (Chain ID 16602). The code falls back to these defaults.
NEXT_PUBLIC_L1_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_TURBO_STORAGE_RPC=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_STANDARD_STORAGE_RPC=https://indexer-storage-testnet-standard.0g.ai

# 0G Storage Flow contract (current Galileo deployment, per docs.0g.ai).
# IMPORTANT: testnet contracts get redeployed. If saves fail with a
# "market() ... BAD_DATA" fee error, this address is stale — update it to the
# current Flow address from docs.0g.ai. Leaving these UNSET uses the code default.
NEXT_PUBLIC_TURBO_FLOW_ADDRESS=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296
NEXT_PUBLIC_STANDARD_FLOW_ADDRESS=0x22E03a6A89B950F1c82ec5e74F8eCa321a105296

# Engram public app registries. Both registries have baked-in Galileo app
# defaults; these envs are overrides for redeploy/testing.
NEXT_PUBLIC_ENGRAM_REGISTRY=
NEXT_PUBLIC_PARCEL_REGISTRY=

# Deploy-only key for scripts/deploy-registry.ts. NEVER expose this in the app
# and never commit a real key.
PRIVATE_KEY=
