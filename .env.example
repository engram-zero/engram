# ─── Engram server configuration ──────────────────────────────────────────────
# Copy this file to .env (in the repo root) and fill in what you have.
# The app runs fully WITHOUT any keys (local file store + mocked NPC dialogue),
# so you can demo immediately and switch real services on when ready.

# Server port
PORT=8787

# ─── NPC AI (Anthropic / Claude) ──────────────────────────────────────────────
# Without a key, NPCs use a deterministic offline persona engine so the demo
# still works. With a key, dialogue is generated by Claude.
ANTHROPIC_API_KEY=
# Model powering the NPCs. Sonnet 4.6 is the default: strong in-character
# writing at a price that fits a chatty game loop. Swap to claude-opus-4-8 for
# max quality or claude-haiku-4-5-20251001 for lowest cost.
ENGRAM_MODEL=claude-sonnet-4-6

# ─── 0G Storage ───────────────────────────────────────────────────────────────
# STORAGE_MODE=local  -> JSON files under server/.data (default, zero setup)
# STORAGE_MODE=zerog  -> real 0G Storage network (the "0G does real work" path)
STORAGE_MODE=local

# Required only when STORAGE_MODE=zerog.
# A funded 0G testnet account that pays for storage writes (the uploader).
# Player identity is still their own wallet — this key only pays gas/fees.
ZEROG_RPC_URL=https://evmrpc-testnet.0g.ai
ZEROG_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai
ZEROG_PRIVATE_KEY=
