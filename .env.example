# ─── Engram environment ───────────────────────────────────────────────────────
# Copy to .env.local and fill in. NEVER commit real keys — .env.local is gitignored.

# NPC AI — Claude (server-side only; never exposed to the browser).
# Without a key, NPCs fall back to a deterministic in-character engine so the UI
# is still clickable.
ANTHROPIC_API_KEY=
# Model powering the NPCs. Sonnet 4.6 = strong in-character writing at chat cost.
# Alternatives: claude-opus-4-8 (max quality) / claude-haiku-4-5-20251001 (cheapest).
ENGRAM_MODEL=claude-sonnet-4-6

# ─── 0G Storage (client-side; the player's wallet pays writes) ────────────────
# WalletConnect project id (https://cloud.walletconnect.com). Optional for injected wallets.
NEXT_PUBLIC_PROJECT_ID=

# 0G Galileo Testnet (Chain ID 16602). The code falls back to these defaults.
NEXT_PUBLIC_L1_RPC=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_TURBO_STORAGE_RPC=https://indexer-storage-testnet-turbo.0g.ai
NEXT_PUBLIC_STANDARD_STORAGE_RPC=https://indexer-storage-testnet-standard.0g.ai
