# dependencies
/node_modules
/.pnp
.pnp.*

# Vercel deploys with pnpm; keep pnpm-lock.yaml as the only lockfile. Installing
# with npm regenerates this and breaks the frozen pnpm install on Vercel.
package-lock.json

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# agent worktrees / scratch copies (never commit these full-project snapshots)
.tmp*/
.tmp-*

# local agent harness config (per-machine; never commit — see CLAUDE.md)
.claude/settings.json
.claude/settings.local.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep secrets out of git, but DO version the template
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Scratch clones of other repos (e.g. opponent code for reference) — never ship.
tmp/
